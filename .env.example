# =========================================
# Environment Variables for Railway
# =========================================

# Server Configuration
PORT=5001
NODE_ENV=production

# Bot Server URL (Static HTML)
# ⚠️ UPDATE THIS with your bot server URL
BOT_URL=https://backend-and-bot-production-8d0d.up.railway.app

# CORS Configuration
CORS_ORIGIN=*

# =========================================
# Puppeteer/Chromium Configuration
# ⚠️ DO NOT ADD THESE MANUALLY IN RAILWAY!
# Railway will set them automatically from nixpacks.toml
# =========================================
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
